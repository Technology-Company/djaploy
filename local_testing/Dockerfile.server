# Target server for local djaploy testing.
# Provides SSH, systemd, nginx, and Python — everything djaploy expects
# on a real deployment target.
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Install required packages
RUN apt-get update && apt-get install -y \
    openssh-server \
    sudo \
    nginx \
    python3 \
    python3-pip \
    python3-venv \
    curl \
    wget \
    git \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install Poetry (as root, available system-wide)
RUN pip3 install poetry

# Create the deploy user (used by djaploy for SSH)
RUN useradd -m -s /bin/bash deploy \
    && echo "deploy:deploy" | chpasswd \
    && usermod -aG sudo deploy \
    && echo "deploy ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# Create the app user (used by djaploy for running the application)
RUN useradd -m -s /bin/bash app \
    && echo "app:app" | chpasswd

# Configure SSH
RUN mkdir -p /var/run/sshd \
    && sed -i 's/#PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config \
    && sed -i 's/#PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config \
    && sed -i 's/#PubkeyAuthentication.*/PubkeyAuthentication yes/' /etc/ssh/sshd_config

# Set up SSH keys for the deploy user
RUN mkdir -p /home/deploy/.ssh \
    && ssh-keygen -t ed25519 -f /home/deploy/.ssh/id_ed25519 -N "" \
    && cat /home/deploy/.ssh/id_ed25519.pub >> /home/deploy/.ssh/authorized_keys \
    && chmod 700 /home/deploy/.ssh \
    && chmod 600 /home/deploy/.ssh/authorized_keys \
    && chown -R deploy:deploy /home/deploy/.ssh

# Remove default nginx site
RUN rm -f /etc/nginx/sites-enabled/default

EXPOSE 22 80

# Start SSH (systemd is not available in Docker, so we start services manually)
COPY scripts/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

CMD ["/entrypoint.sh"]
