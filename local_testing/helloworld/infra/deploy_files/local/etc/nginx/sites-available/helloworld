upstream helloworld {
    server unix:/home/app/apps/helloworld/current/helloworld.sock fail_timeout=0;
}

server {
    listen 80 default_server;
    server_name _;

    client_max_body_size 10M;

    location /static/ {
        alias /home/app/apps/helloworld/shared/staticfiles/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    location /media/ {
        alias /home/app/apps/helloworld/shared/media/;
        expires 30d;
    }

    location / {
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_redirect off;
        proxy_pass http://helloworld;
    }
}
